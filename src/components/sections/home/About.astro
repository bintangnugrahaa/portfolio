---
// components
import Heading from "../../elements/Heading.astro";
import Text from "../../elements/Text.astro";
import Container from "../../elements/Container.astro";
import Link from "../../elements/Link.astro";
import ImageContainer from "../../elements/ImageContainer.astro";

// assets
import bintang2 from "../../../assets/images/bintang2.jpeg";
---

<Container variant={"xl"}>
  <Heading tagName="h2" tagSize="h2" class="text-center">About</Heading>
  <div class="flex lg:flex-row lg:gap-16 gap-10 flex-col">
    <div
      class="flex flex-col items-start gap-6 lg:pt-6 text-base-900 lg:flex-1"
    >
      <Text variant={"xl"}
        >I'm a dedicated problem-solver who thrives at the intersection of
        software engineering, cloud architecture, and system optimization.</Text
      >
      <Text variant={"sm"}
        >With a strong foundation in full-stack development, I help
        organizations translate complex technical requirements into scalable,
        efficient, and user-friendly web applications.</Text
      >
      <Text variant={"sm"}
        >When I'm not coding or managing cloud infrastructure, you'll often find
        me mentoring students as an assistant lecturer or sharing knowledge
        within tech communities. I believe the best digital solutions are built
        on collaboration and a deep understanding of core programming concepts.</Text
      >
      <Link variant={"button"} href="/about">More about me</Link>
    </div>
    <div class="w-full lg:h-[500px] h-auto lg:flex-1">
      <ImageContainer src={bintang2} alt="Muhammad Bintang Nugraha" />
    </div>
  </div>
</Container>
